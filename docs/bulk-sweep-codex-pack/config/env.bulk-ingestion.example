# Homebox Companion Bulk Sweep example env additions

# Existing core settings
HBC_LLM_API_KEY=sk-your-key-or-proxy-key
# For Thomas' homelab, prefer a vision-capable AI Proxy provider for photo extraction.
# Codex bridge providers are useful for text-only reasoning, but the current bridge
# omits image/audio payloads before forwarding to Codex.
HBC_LLM_MODEL=ai-node
HBC_LLM_API_BASE=http://192.168.1.248:8880/v1
HBC_LLM_ALLOW_UNSAFE_MODELS=true
HBC_HOMEBOX_URL=http://homebox:7745

# Bulk Sweep
HBC_BULK_ENABLED=true
HBC_BULK_MAX_IMAGES=120
HBC_BULK_MAX_FILE_SIZE_MB=10
HBC_BULK_VISION_CHUNK_SIZE=8
HBC_BULK_MAX_TRANSCRIPT_CHARS=20000
HBC_BULK_MAX_ATTACHMENTS_PER_ITEM=4
HBC_BULK_LOW_CONFIDENCE_THRESHOLD=0.65
HBC_BULK_AUTO_ACCEPT_THRESHOLD=0.90

# Optional bulk model override; leave empty to use HBC_LLM_MODEL
HBC_BULK_LLM_MODEL=

# Audio transcription
HBC_AUDIO_TRANSCRIPTION_ENABLED=true
HBC_AUDIO_MAX_FILE_SIZE_MB=50
HBC_AUDIO_TRANSCRIPTION_MODEL=whisper-1
# Leave these empty to fallback to HBC_LLM_API_BASE / HBC_LLM_API_KEY where compatible
HBC_AUDIO_API_BASE=
HBC_AUDIO_API_KEY=
